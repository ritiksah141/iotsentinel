# ===========================================================================
# IoTSentinel — Environment Variables
# ===========================================================================
# Copy this file to .env and fill in values for your deployment.
# Lines starting with # are comments.  Empty values disable the feature.
# ===========================================================================

# ─── Flask / Dashboard ─────────────────────────────────────────────────────
# A strong random secret. Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=

# Dashboard bind address / port / debug toggle
IOTSENTINEL_HOST=0.0.0.0
IOTSENTINEL_PORT=8050
IOTSENTINEL_DEBUG=false

# Set to "true" when serving over HTTPS (enables Secure cookie flag)
IOTSENTINEL_HTTPS=false

# Allowed CORS origins for SocketIO (default: * — restrict in production!)
# Example: http://192.168.1.100:8050
IOTSENTINEL_CORS_ORIGINS=*

# ─── Default Admin Account ─────────────────────────────────────────────────
# Password for the auto-created admin user (on first run only).
# If unset, a random password is generated and printed in the logs.
IOTSENTINEL_ADMIN_PASSWORD=

# ─── AI Assistant ──────────────────────────────────────────────────────────
# Groq cloud API key (free tier: 14,400 requests/day)
GROQ_API_KEY=

# OpenAI API key (paid — used for Business tier; enables gpt-4o-mini)
OPENAI_API_KEY=

# Anthropic API key (paid — enables Claude Haiku)
ANTHROPIC_API_KEY=

# Google Gemini API key (free tier: about 250 requests/day — backup to Groq)
GEMINI_API_KEY=

# ─── Email / SMTP ─────────────────────────────────────────────────────────
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=
EMAIL_SENDER_EMAIL=
EMAIL_RECIPIENT_EMAIL=

# ─── Push Notifications ───────────────────────────────────────────────
# ntfy.sh (zero-account phone push — zero-config default)
# Subscribe on your phone at https://ntfy.sh/<topic> or via the ntfy app.
NOTIFICATIONS_NTFY_ENABLED=false
NOTIFICATIONS_NTFY_SERVER=https://ntfy.sh
NOTIFICATIONS_NTFY_TOPIC=

# Telegram Bot (obtain token from BotFather, chat_id from @userinfobot)
NOTIFICATIONS_TELEGRAM_ENABLED=false
NOTIFICATIONS_TELEGRAM_BOT_TOKEN=
NOTIFICATIONS_TELEGRAM_CHAT_ID=

# Discord webhook
# Create in Server Settings > Integrations > Webhooks
NOTIFICATIONS_DISCORD_ENABLED=false
NOTIFICATIONS_DISCORD_WEBHOOK_URL=

# Generic JSON webhook (n8n, Zapier, Make, Home Assistant, etc.)
NOTIFICATIONS_WEBHOOK_ENABLED=false
NOTIFICATIONS_WEBHOOK_URL=

# ─── Threat Intelligence ──────────────────────────────────────────────
THREAT_INTELLIGENCE_ABUSEIPDB_API_KEY=

# ─── NVD (National Vulnerability Database) ─────────────────────────────
NVD_API_KEY=

# ─── Remote access (Tailscale Funnel / any reverse proxy) ────────────
# Set this to your public URL (e.g. https://sentinel.ts.net) when exposing
# the dashboard outside your LAN.  WebAuthn rp_id/origin and the OAuth
# redirect URI are derived from this value automatically — you only need
# to set the explicit overrides below if your setup is non-standard.
IOTSENTINEL_PUBLIC_URL=

# ─── Google OAuth (optional) ──────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Derived from IOTSENTINEL_PUBLIC_URL when blank
OAUTH_REDIRECT_URI=

# ─── WebAuthn / Passkeys (optional) ──────────────────────────────────
# Both derived from IOTSENTINEL_PUBLIC_URL when blank
WEBAUTHN_RP_ID=
WEBAUTHN_RP_NAME=IoTSentinel
WEBAUTHN_ORIGIN=

# ─── Reverse Proxy ────────────────────────────────────────────────────
# Set to "true" if the dashboard sits behind nginx / Caddy / Cloudflare
IOTSENTINEL_BEHIND_PROXY=false

# ─── Encryption ───────────────────────────────────────────────────────
# Fernet key for encrypting sensitive config values.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
IOTSENTINEL_ENCRYPTION_KEY=

# ─── Runtime Environment ──────────────────────────────────────────────
# "production" or "development" (affects error verbosity, etc.)
IOTSENTINEL_ENV=production

# ─── Logging ──────────────────────────────────────────────────────────
CONSOLE_LOGGING=true
STRUCTURED_LOGGING=false
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
ASYNC_LOGGING=false
